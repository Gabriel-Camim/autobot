RAG_K=8
RAG_LEXICAL_K=4
RAG_MAX_DISTANCE=1.55
RAG_MIN_DOCS=1
RAG_MAX_CONTEXT_CHARS=14000
RAG_AUTO_REINDEX_ON_MISSING=true
RAG_AUTO_REINDEX_WAIT_SECONDS=90
RAG_EXCLUDED_SOURCE_PREFIXES=reports/
VECTORSTORE_BACKEND=chroma
PGVECTOR_TABLE=rag_chunks
PGVECTOR_DIMENSION=3072

FRONTEND_ORIGINS=https://frontend-nbecvxa81-camim2003-1759s-projects.vercel.app
