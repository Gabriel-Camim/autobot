OPENAI_API_KEY=replace_with_your_rotated_openai_key
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_FAST_CHAT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TRANSCRIBE_MODEL=whisper-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
REALTIME_ENABLED=false
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
REALTIME_MAX_SESSION_SECONDS=420
REALTIME_MAX_CONTEXT_CHARS=9000
PUBLIC_WARMUP_MIN_INTERVAL_SECONDS=300
OPENAI_TEMPERATURE=0.1
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=medium
OPENAI_USE_RESPONSES_API=true

APP_ENV=development
PUBLIC_BACKEND_URL=
PUBLIC_FRONTEND_URL=

CHROMA_DIR=./chroma
CHROMA_COLLECTION=gabriel_portfolio
